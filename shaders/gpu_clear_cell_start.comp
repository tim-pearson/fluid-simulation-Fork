#version 430 core

// Clear the cellStart buffer to 0xFFFFFFFF (empty cell marker)

layout(local_size_x = 256) in;

layout(std430, binding = 5) buffer CellStartBuffer {
    uint cellStart[];
};

uniform uint numCells;

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= numCells) return;
    
    cellStart[idx] = 0xFFFFFFFFu;
}